<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
    This is the default, RELEASE configuration.
    It disallows all cleartext traffic and only trusts system-provided certificates.
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
